# Normalize line endings to LF on check-in, convert to OS native on checkout
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Treat binaries as binary
*.png binary
*.jpg binary
*.ico binary
